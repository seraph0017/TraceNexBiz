# dev (.env)：复制为 .env 并填值；prod 走 K8s ConfigMap + Secret + KMS Secret Manager.
APP_ENV=dev
PORT=8080

# DSN
BIZ_DSN=mysql://tnbiz_app:tnbiz_app_pw@tcp(127.0.0.1:3306)/partner_db?parseTime=true&charset=utf8mb4&collation=utf8mb4_0900_ai_ci
LOG_DSN=mysql://tnbiz_app:tnbiz_app_pw@tcp(127.0.0.1:3306)/log_db?parseTime=true
FY_DSN=mysql://tnbiz_app:tnbiz_app_pw@tcp(127.0.0.1:3306)/fy_api_db?parseTime=true

# Redis
REDIS_ADDR=127.0.0.1:6379

# KMS / OSS / SLS（dev 用 noop）
KMS_ENDPOINT=
KMS_KEY_ID=noop:dev
OSS_ENDPOINT=http://127.0.0.1:4566
OSS_BUCKET_PII=tnbiz-dev-pii
OSS_BUCKET_ARCHIVE=tnbiz-dev-archive
SLS_PROJECT=tnbiz-dev

# Fy-api 内部 API
FY_API_BASE=http://127.0.0.1:3000
FY_API_KEY_ID=tnbiz-dev
FY_API_KEY_SECRET=tnbiz-dev-secret

# JWT（dev 占位；prod 走 KMS Secret Manager）
JWT_VERIFY_KEY_PEM=

# 持牌方（Q12 决策前 stub）
LICENSED_PROVIDER=stub

# Idempotency / Saga 上限（启动 invariant 校验）
SAGA_WALL_CLOCK_HOURS=1
IDEMPOTENCY_TTL_HOURS=24
INTERNAL_IDEMPOTENCY_TTL_DAYS=7
